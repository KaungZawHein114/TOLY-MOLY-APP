# ── Local indexer config (functions/.env.local) ────────────────────────────
# Copy this file to functions/.env.local and fill in real values.
# functions/.env.local is git-ignored AND never loaded by `firebase deploy`
# (unlike functions/.env). These keys are used ONLY by
# scripts/index_knowledge.js when run locally — the DEPLOYED Cloud Function
# reads its keys from Firebase Secret Manager instead, never from this file.

OPENAI_API_KEY=sk-...
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX=tolymoly-knowledge

# Optional — only needed if the index doesn't exist yet and must be created.
# Defaults: aws / us-east-1 (Pinecone serverless free tier).
# PINECONE_CLOUD=aws
# PINECONE_REGION=us-east-1

# Optional — override the knowledge folder location (default: ../knowledge).
# KNOWLEDGE_DIR=../knowledge
